{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://incursa.com/schemas/string-backed-enum.schema.json",
  "title": "String Backed Enum",
  "description": "Schema for Incursa string-backed enum types (.enum.json, .string_enum.json)",
  "type": "object",
  "required": ["name", "namespace", "values"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the enum type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "namespace": {
      "type": "string",
      "description": "The .NET namespace for the generated enum.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
    },
    "values": {
      "type": "object",
      "description": "Enum members keyed by member name.",
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": "string",
              "description": "String value for the enum member."
            },
            "display": {
              "type": "string",
              "description": "Display name; defaults to member name when omitted."
            },
            "documentation": {
              "type": "string",
              "description": "XML documentation text for this enum member."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "properties": {
      "type": "object",
      "description": "Additional property definitions keyed by property name.",
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "description": "C# type for this additional property.",
              "examples": ["string", "int", "bool", "DateTime", "decimal"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "AccountingSystemEnum",
      "namespace": "Incursa.Enums",
      "properties": {
        "SystemId": {
          "type": "int"
        },
        "ApiEndpoint": {
          "type": "string"
        }
      },
      "values": {
        "None": {
          "value": "none",
          "documentation": "No accounting system selected."
        },
        "ViewpointVista": {
          "value": "viewpoint_vista",
          "display": "Viewpoint Vista"
        }
      }
    }
  ]
}
