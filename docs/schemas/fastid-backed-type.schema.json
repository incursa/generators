{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://incursa.com/schemas/fastid-backed-type.schema.json",
  "title": "FastId Backed Type",
  "description": "Schema for Incursa FastId-backed value types (.fastid.json)",
  "type": "object",
  "required": ["name", "namespace"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the FastId type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "namespace": {
      "type": "string",
      "description": "The .NET namespace for the generated type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "UserId",
      "namespace": "Incursa.Identifiers"
    },
    {
      "name": "OrderId",
      "namespace": "Incursa.Identifiers"
    }
  ]
}
