{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://incursa.com/schemas/guid-backed-type.schema.json",
  "title": "GUID Backed Type",
  "description": "Schema for Incursa GUID-backed value types (.guid.json)",
  "type": "object",
  "required": ["name", "namespace"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the GUID type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "namespace": {
      "type": "string",
      "description": "The .NET namespace for the generated type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
    },
    "defaultFormat": {
      "description": "Optional toggle consumed as bool. Parser accepts boolean or a string parseable as true/false.",
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "enum": ["true", "false", "True", "False"]
        }
      ],
      "default": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "CustomerId",
      "namespace": "Incursa.Identifiers"
    },
    {
      "name": "OrderId",
      "namespace": "Incursa.Identifiers",
      "defaultFormat": true
    }
  ]
}
