{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://incursa.com/schemas/multi-value-backed-type.schema.json",
  "title": "Multi-Value Backed Type",
  "description": "Schema for Incursa multi-value backed types (.multi.json)",
  "type": "object",
  "required": ["name", "namespace"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the multi-value type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "namespace": {
      "type": "string",
      "description": "The .NET namespace for the generated type.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
    },
    "separator": {
      "type": "string",
      "description": "Separator used between parts when format is not used.",
      "default": "|"
    },
    "format": {
      "type": "string",
      "description": "Optional composite format string behavior trigger."
    },
    "regex": {
      "type": "string",
      "description": "Optional explicit regex pattern used for parsing/validation generation."
    },
    "bookend": {
      "type": "string",
      "description": "Optional leading/trailing marker around serialized value."
    },
    "nullIdentifier": {
      "type": "string",
      "description": "Default token used for nullable part serialization."
    },
    "parts": {
      "type": "array",
      "description": "Parts that compose the multi-value type.",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Part name.",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "type": {
            "type": "string",
            "description": "C# type for this part.",
            "default": "string",
            "examples": ["string", "int", "long", "Guid", "DateTime"]
          },
          "serializedName": {
            "type": "string",
            "description": "Optional serialized key/name prefix for this part."
          },
          "constantValue": {
            "type": "string",
            "description": "Optional constant textual value for this part."
          },
          "constantTypeValue": {
            "type": "string",
            "description": "Optional constant typed expression for this part."
          },
          "isNullable": {
            "type": "boolean",
            "description": "Whether the part is nullable.",
            "default": false
          },
          "nullIdentifier": {
            "type": "string",
            "description": "Nullable token override for this part."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "CompositeCode",
      "namespace": "Incursa.ValueTypes",
      "separator": "|",
      "parts": [
        {
          "name": "Region",
          "type": "string"
        },
        {
          "name": "Sequence",
          "type": "int"
        }
      ]
    },
    {
      "name": "BookendedCode",
      "namespace": "Incursa.ValueTypes",
      "bookend": "#",
      "nullIdentifier": "NULL",
      "parts": [
        {
          "name": "Tenant",
          "type": "string"
        },
        {
          "name": "Revision",
          "type": "int",
          "isNullable": true
        }
      ]
    }
  ]
}
