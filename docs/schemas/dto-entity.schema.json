{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://incursa.com/schemas/dto-entity.schema.json",
  "title": "DTO/Entity Type",
  "description": "Schema for Incursa DTO and Entity definitions (.dto.json, .entity.json)",
  "type": "object",
  "required": ["name", "namespace"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the DTO/Entity class.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "namespace": {
      "type": "string",
      "description": "The .NET namespace for the generated class.",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
    },
    "inherits": {
      "type": "string",
      "description": "Base type and/or interfaces, used as-is in generated type declaration.",
      "examples": ["BaseDto", "BaseEntity, ITimestamped"]
    },
    "abstract": {
      "type": "boolean",
      "description": "Whether this generated type is abstract.",
      "default": false
    },
    "accessibility": {
      "type": "string",
      "description": "Access modifier emitted before the generated type.",
      "enum": ["public", "internal", "protected", "private"],
      "default": "public"
    },
    "documentation": {
      "type": "string",
      "description": "XML documentation summary text for the type."
    },
    "classOnly": {
      "type": "boolean",
      "description": "Controls class-only generation mode used by nested generation paths.",
      "default": false
    },
    "strict": {
      "type": "boolean",
      "description": "When true, strict DTO semantics are applied.",
      "default": false
    },
    "useParentValidator": {
      "type": "boolean",
      "description": "When true, validator generation can chain to parent validator where applicable.",
      "default": true
    },
    "noCreateMethod": {
      "type": "boolean",
      "description": "When true, suppresses generated Create(...) factory method.",
      "default": false
    },
    "isRecordStruct": {
      "type": "boolean",
      "description": "When true, generates a record struct instead of record class.",
      "default": false
    },
    "properties": {
      "type": "array",
      "description": "Property definitions for the generated type.",
      "items": {
        "$ref": "#/definitions/propertyDefinition"
      }
    },
    "nestedEntities": {
      "type": "array",
      "description": "Nested DTO/entity definitions. Nested entries inherit parent namespace when namespace is omitted.",
      "items": {
        "$ref": "#/definitions/nestedEntityDefinition"
      }
    }
  },
  "definitions": {
    "propertyDefinition": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Property name.",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "description": "C# type for this property.",
          "examples": ["string", "int", "bool", "DateTime", "Guid", "List<string>"]
        },
        "required": {
          "type": "boolean",
          "description": "Required-ness in generated validation and required-member keyword behavior.",
          "default": true
        },
        "nullable": {
          "type": "boolean",
          "description": "Whether nullable syntax should be used for this property.",
          "default": false
        },
        "settable": {
          "type": "boolean",
          "description": "When true, emits set accessor; otherwise init accessor.",
          "default": false
        },
        "noDefault": {
          "type": "boolean",
          "description": "When true, suppresses default initializer usage even if defaultValue is provided.",
          "default": false
        },
        "max": {
          "type": "string",
          "description": "Maximum constraint input used by generated validation attributes.",
          "examples": ["100", "255", "2026-12-31"]
        },
        "min": {
          "type": "string",
          "description": "Minimum constraint input used by generated validation attributes.",
          "examples": ["1", "0", "1900-01-01"]
        },
        "regex": {
          "type": "string",
          "description": "Regular expression constraint for string properties."
        },
        "jsonProperty": {
          "type": "string",
          "description": "Custom JSON property name via [JsonPropertyName]."
        },
        "defaultValue": {
          "type": "string",
          "description": "Raw C# initializer expression.",
          "examples": ["\"default\"", "0", "true", "DateTime.UtcNow", "new List<string>()"]
        },
        "expression": {
          "type": "string",
          "description": "Computed property expression (expression-bodied property)."
        },
        "documentation": {
          "type": "string",
          "description": "XML documentation text for this property."
        }
      },
      "additionalProperties": false
    },
    "nestedEntityDefinition": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Nested type name.",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "namespace": {
          "type": "string",
          "description": "Optional for nested entities; if omitted, parent namespace is used.",
          "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
        },
        "inherits": {
          "type": "string"
        },
        "abstract": {
          "type": "boolean",
          "default": false
        },
        "accessibility": {
          "type": "string",
          "enum": ["public", "internal", "protected", "private"],
          "default": "public"
        },
        "documentation": {
          "type": "string"
        },
        "classOnly": {
          "type": "boolean",
          "default": false
        },
        "strict": {
          "type": "boolean",
          "default": false
        },
        "useParentValidator": {
          "type": "boolean",
          "default": true
        },
        "noCreateMethod": {
          "type": "boolean",
          "default": false
        },
        "isRecordStruct": {
          "type": "boolean",
          "default": false
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/propertyDefinition"
          }
        },
        "nestedEntities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/nestedEntityDefinition"
          }
        }
      },
      "allOf": [
        {
          "not": {
            "properties": {
              "abstract": {
                "const": true
              },
              "strict": {
                "const": true
              }
            },
            "required": ["abstract", "strict"]
          }
        },
        {
          "if": {
            "properties": {
              "isRecordStruct": {
                "const": true
              }
            },
            "required": ["isRecordStruct"]
          },
          "then": {
            "properties": {
              "abstract": {
                "const": false
              },
              "inherits": {
                "maxLength": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "strict": {
                "const": true
              }
            },
            "required": ["strict"]
          },
          "then": {
            "properties": {
              "properties": {
                "not": {
                  "contains": {
                    "type": "object",
                    "properties": {
                      "settable": {
                        "const": true
                      }
                    },
                    "required": ["settable"]
                  }
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "abstract": {
            "const": true
          },
          "strict": {
            "const": true
          }
        },
        "required": ["abstract", "strict"]
      }
    },
    {
      "if": {
        "properties": {
          "isRecordStruct": {
            "const": true
          }
        },
        "required": ["isRecordStruct"]
      },
      "then": {
        "properties": {
          "abstract": {
            "const": false
          },
          "inherits": {
            "maxLength": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "strict": {
            "const": true
          }
        },
        "required": ["strict"]
      },
      "then": {
        "properties": {
          "properties": {
            "not": {
              "contains": {
                "type": "object",
                "properties": {
                  "settable": {
                    "const": true
                  }
                },
                "required": ["settable"]
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "examples": [
    {
      "name": "PersonDto",
      "namespace": "Incursa.Models.Dtos",
      "strict": true,
      "properties": [
        {
          "name": "Id",
          "type": "Guid",
          "required": true,
          "settable": false,
          "documentation": "The unique identifier."
        },
        {
          "name": "Email",
          "type": "string",
          "required": true,
          "regex": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$",
          "jsonProperty": "email"
        },
        {
          "name": "DisplayName",
          "type": "string",
          "defaultValue": "\"Unknown\""
        }
      ],
      "nestedEntities": [
        {
          "name": "Metadata",
          "properties": [
            {
              "name": "Source",
              "type": "string",
              "required": true
            }
          ]
        }
      ]
    }
  ]
}
